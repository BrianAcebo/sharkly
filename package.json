{
	"name": "Paperboat CRM",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "concurrently -n api,web,tunnel -c cyan,green,yellow \"npm run dev:server\" \"npm run dev:frontend\" \"npm run dev:ngrok\"",
		"dev:frontend": "vite",
		"dev:server": "tsx watch api/src/index.ts",
		"dev:ngrok": "node scripts/ngrok-serve.mjs",
		"// note": "---- API build/run (for Fly & local preview) ----",
		"api:watch": "tsc -p api/tsconfig.json -w",
		"api:start": "node api/dist/index.js",
		"// note2": "---- Full build: Vite + API (outputs server-dist/) ----",
		"build": "tsc -b && vite build && tsc -p api/tsconfig.json",
		"build:api": "tsc -p api/tsconfig.json",
		"// note3": "---- Local preview of built artifacts ----",
		"start": "concurrently -n web,api -c green,cyan \"npm run start:frontend\" \"npm run start:server\"",
		"start:frontend": "vite preview",
		"start:server": "node api/dist/index.js",
		"// note4": "---- Utilities ----",
		"stop": "tsx scripts/stop-dev.ts 3000",
		"lint": "eslint .",
		"preview": "vite preview",
		"// note5": "---- Optional: one-liner to deploy API on Fly ----",
		"fly:deploy": "fly deploy --remote-only -a paperboat-crm-api",
		"// note6": "---- Supabase (DB) ----",
		"db:start": "docker compose -f supabase/docker/docker-compose.yml up -d",
		"db:stop": "docker compose -f supabase/docker/docker-compose.yml down",
		"db:pull": "docker compose -f supabase/docker/docker-compose.yml pull",
		"db:reset": "docker compose -f supabase/docker/docker-compose.yml down -v && docker compose -f supabase/docker/docker-compose.yml up -d",
		"db:logs": "docker compose -f supabase/docker/docker-compose.yml logs -f kong db auth rest studio"
	},
	"dependencies": {
		"@dnd-kit/core": "^6.3.1",
		"@dnd-kit/sortable": "^10.0.0",
		"@dnd-kit/utilities": "^3.2.2",
		"@fullcalendar/core": "^6.1.19",
		"@fullcalendar/daygrid": "^6.1.19",
