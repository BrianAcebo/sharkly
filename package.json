		"@supabase/auth-ui-react": "^0.4.7",
		"@supabase/auth-ui-shared": "^0.1.8",
		"@supabase/supabase-js": "^2.50.0",
		"@twilio/voice-sdk": "^2.15.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"cmdk": "^1.1.1",
		"cors": "^2.8.5",
		"date-fns": "^4.1.0",
		"date-fns-tz": "^3.2.0",
		"dotenv": "^17.2.1",
		"embla-carousel-react": "^8.6.0",
		"express": "^5.1.0",
		"flatpickr": "^4.6.13",
		"framer-motion": "^12.23.6",
