---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getFeaturedPosts } from '../lib/supabase';
import { buildStaticMarketingPageJsonLd } from '../lib/sitePageJsonLd';
import { Star, DollarSign, Brain, Clock, Bot, TrendingDown, MapPinX } from '@lucide/astro';

const siteUrl = import.meta.env.MARKETING_URL ?? 'https://sharkly.co';
const appUrl = import.meta.env.FRONTEND_URL ?? 'https://app.sharkly.co';
const featuredPosts = await getFeaturedPosts(3);

const homeDescription =
  'The AI SEO strategist for people who have a business to run. Expert-level SEO, fully automated.';
const schema = buildStaticMarketingPageJsonLd({
  siteUrl,
  appUrl,
  canonicalUrl: siteUrl,
  pageName: 'Sharkly — SEO platform for non-experts',
  description: homeDescription,
  breadcrumbItems: [{ name: 'Home', path: '/' }],
  websiteExtras: {
    potentialAction: {
      '@type': 'SearchAction',
      target: { '@type': 'EntryPoint', urlTemplate: `${appUrl}/strategy?q={search_term_string}` },
      'query-input': 'required name=search_term_string',
    },
  },
});
---

<BaseLayout title="Easy AI SEO for Busy Businesses" description={homeDescription} canonical={siteUrl} schema={schema}>

<style is:global>
  /* ── Scenic gradient card behind UI mockups ── */
  .scenic-card {
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 28px 80px rgba(0,0,0,.18);
  }
  .scenic-bg { height: 80px; }
  .scenic-panel {
    background: #fff;
    border-radius: 10px 10px 0 0;
    margin: 0 16px;
    transform: translateY(-28px);
    box-shadow: 0 4px 20px rgba(0,0,0,.12);
    overflow: hidden;
  }
  .dark .scenic-panel { background: #171717; }
  .scenic-topbar {
    display: flex; align-items: center; gap: 5px;
    padding: 9px 12px;
    border-bottom: 1px solid rgba(0,0,0,.08);
    background: #f5f5f4;
  }
  .dark .scenic-topbar { background: #262626; border-color: rgba(255,255,255,.08); }
  .mac-dot { width: 9px; height: 9px; border-radius: 50%; }
  .scenic-titlebar { flex: 1; height: 12px; background: #e7e5e4; border-radius: 3px; margin: 0 8px; }
  .dark .scenic-titlebar { background: #333; }

  /* ── Pain point cards ── */
  .pain-card {
    background: #fff;
    border: 1px solid rgba(0,0,0,.08);
    border-radius: 14px;
    padding: 24px;
    box-shadow: 0 2px 12px rgba(0,0,0,.06);
  }
  .dark .pain-card { background: #1a1a1a; border-color: rgba(255,255,255,.08); }

  /* ── Pricing card highlight ── */
  .pricing-card {
    border-radius: 20px;
    border: 1px solid rgba(0,0,0,.1);
    overflow: hidden;
    transition: transform .2s ease, box-shadow .2s ease;
  }
  .pricing-card:hover { transform: translateY(-4px); box-shadow: 0 24px 60px rgba(0,0,0,.14); }
  .pricing-card.featured {
    border-color: transparent;
    box-shadow: 0 0 0 2px #171717, 0 20px 60px rgba(0,0,0,.18);
  }
  .dark .pricing-card.featured { box-shadow: 0 0 0 2px #f5f5f0, 0 20px 60px rgba(0,0,0,.4); }

  /* ── Testimonial ── */
  .testimonial-card {
    background: #fff;
    border: 1px solid rgba(0,0,0,.08);
    border-radius: 16px;
    padding: 28px;
    box-shadow: 0 4px 20px rgba(0,0,0,.06);
  }
  .dark .testimonial-card { background: #1a1a1a; border-color: rgba(255,255,255,.08); }

  /* ── Scroll reveal ── */
  .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.55s ease, transform 0.55s ease;
  }
  .reveal.visible { opacity: 1; transform: none; }

  /* ── Urgency banner ── */
  @keyframes pulse-soft {
    0%, 100% { opacity: 1; }
    50% { opacity: .7; }
  }
  .urgency-dot { animation: pulse-soft 2s ease infinite; }

  /* ── Stats counter ── */
  .stat-number {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1;
  }
</style>


<section id="hero" class="bg-stone-100 dark:bg-neutral-900 md:pt-20 pt-10 pb-0 px-6 overflow-hidden">
  <div class="max-w-[1200px] mx-auto">

    <!-- Centred text -->
    <div class="text-center max-w-5xl mx-auto mb-14 space-y-6">

      <!-- Social proof badge — tiny trust signal immediately -->
      <div class="inline-flex items-center gap-2 bg-emerald-50 dark:bg-emerald-950/50 border border-emerald-200 dark:border-emerald-800 text-emerald-800 dark:text-emerald-400 px-4 py-1.5 rounded-full text-xs font-semibold">
        <span class="urgency-dot w-1.5 h-1.5 rounded-full bg-emerald-500 inline-block"></span>
        Trusted by 1,200+ small business owners — from $39/mo
      </div>

      <h1 class="text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-extrabold text-neutral-900 dark:text-stone-100 md:tracking-tight">
        Finally, an SEO platform that's<br/><span class="text-neutral-500 dark:text-neutral-400">not for SEO experts.</span>
      </h1>

      <p class="text-lg lg:text-xl text-gray-600 dark:text-gray-400 leading-relaxed max-w-2xl mx-auto">
        Sharkly is your AI SEO strategist. It handles everything — strategy, content, rankings — so you can focus on running your business.
      </p>

      <!-- Primary CTA — low friction, high incentive -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3 pt-2">
        <a href={`${appUrl}/signup`} class="inline-flex items-center gap-2.5 bg-neutral-900 dark:bg-stone-100 text-white dark:text-neutral-900 px-7 py-3.5 rounded-full text-[0.9375rem] font-bold no-underline transition-opacity hover:opacity-85 shadow-lg">
          Start your free 7-day trial →
        </a>
      </div>

    </div>

    <!-- 4-photo row -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-2.5">
      <img src="https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?w=700" alt="Ecommerce store owner" loading="eager" class="w-full aspect-[4/3] object-cover rounded-xl" />
      <img src="https://images.unsplash.com/photo-1573612664822-d7d347da7b80?w=700" alt="Small business boutique shop" loading="eager" class="w-full aspect-[4/3] object-cover rounded-xl" />
      <img src="https://images.unsplash.com/photo-1542744173-8e7e53415bb0?w=700" alt="Business growth" loading="eager" class="w-full aspect-[4/3] object-cover rounded-xl" />
      <img src="https://images.unsplash.com/photo-1460925895917-afdab827c52f?w=700" alt="Analytics dashboard" loading="eager" class="w-full aspect-[4/3] object-cover rounded-xl" />
    </div>

  </div>
</section>

<section class="bg-stone-100 dark:bg-neutral-900 px-6 pt-16 pb-16">
  <div class="max-w-[1200px] mx-auto">
    <hr class="border-0 border-t border-black/10 dark:border-white/10 mb-12" />
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-8">
      {[
        { num: '1,200+', label: 'Small businesses ranked' },
        { num: '4.8',   label: 'Average customer rating', icon: <Star className="size-6 fill-current" /> },
        { num: '~10 min',label: 'To your first SEO strategy' },
        { num: '$39/mo', label: 'Starting price — less than a dinner', },
      ].map((s, i) => (
        <div class={`reveal text-center`} style={`transition-delay:${i*80}ms`}>
            <div class="flex items-center justify-center mb-2">
                <p class="stat-number text-neutral-900 dark:text-stone-100 mb-1">{s.num}</p>
                {s.icon && <div class="flex items-center justify-center mb-2">{s.icon}</div>}
            </div>
          <p class="text-sm text-gray-500 dark:text-gray-400 leading-snug">{s.label}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<section id="research" class="bg-stone-200 dark:bg-neutral-800 border-t border-black/10 dark:border-white/10 py-14 px-6">
  <div class="max-w-3xl mx-auto text-center reveal">
    <p class="text-xs font-bold uppercase tracking-widest text-gray-400 mb-4">Why Sharkly actually works</p>
    <p class="text-xl sm:text-2xl font-extrabold text-neutral-900 dark:text-stone-100 tracking-tight leading-snug mb-4">
      Our algorithms are built on Google's own patents — the same science Google uses to rank your competitors.
    </p>
    <p class="text-base text-gray-600 dark:text-gray-400 leading-relaxed max-w-[580px] mx-auto mb-10">
      Most SEO tools guess. Sharkly doesn't. Every recommendation we make is backed by published research, Google's own <a href="/blog/research/google-patents-behind-sharkly" target="_blank" class="text-blue-500 dark:text-blue-300">patent filings</a>, and thousands of data points specific to your site. This isn't AI hype — it's applied search science.
    </p>
    <!-- Logo trust row -->
    <div class="flex items-center justify-center gap-8 sm:gap-12 flex-wrap opacity-45 grayscale dark:opacity-30">
      <span class="text-base font-extrabold tracking-tight text-neutral-900 dark:text-stone-100">Google Patent Research</span>
      <span class="text-base font-extrabold tracking-tight text-neutral-900 dark:text-stone-100">Authority Progression Modelling</span>
      <span class="text-base font-extrabold tracking-tight text-neutral-900 dark:text-stone-100">Search Intent Analysis</span>
    </div>
  </div>
</section>

<section class="bg-stone-100 dark:bg-neutral-900 border-t border-black/10 dark:border-white/10 py-24 px-6">
  <div class="max-w-[1200px] mx-auto">

    <div class="max-w-[640px] mb-14 reveal">
      <p class="text-xs font-bold uppercase tracking-widest text-gray-400 mb-4">Sound familiar?</p>
      <h2 class="text-3xl sm:text-4xl font-extrabold text-neutral-900 dark:text-stone-100 tracking-tight leading-tight mb-4">
        You know SEO matters.<br/>You just can't make it happen.
      </h2>
      <p class="text-base text-gray-600 dark:text-gray-400 leading-relaxed">
        You're not alone. Every small business owner feels this. And it's not your fault — SEO was never designed for people with a business to run.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {[
        {
          icon: <DollarSign className="size-6" />,
          title: '"An SEO agency wants $3,000 a month."',
          body: 'That\'s more than your rent. Agencies are built for big brands with big budgets — not the small business owner trying to grow.',
        },
        {
          icon: <Brain className="size-6" />,
          title: '"I tried the tools. I had no idea what I was looking at."',
          body: 'Semrush, Ahrefs, Moz — they\'re built for marketers with years of training. Tabs everywhere, numbers without context, zero guidance on what to do next.',
        },
        {
          icon: <Clock className="size-6" />,
          title: '"I don\'t have 10 hours a week to learn SEO."',
          body: 'You\'re running a business. Shipping orders, answering customers, managing suppliers. SEO homework isn\'t on the agenda.',
        },
        {
          icon: <Bot className="size-6" />,
          title: '"ChatGPT wrote me articles. Nothing ranked."',
          body: 'Content without strategy is just noise. You need the right keywords, the right structure, the right authority — not just words on a page.',
        },
        {
          icon: <TrendingDown className="size-6" />,
          title: '"Competitors keep outranking me and I don\'t know why."',
          body: 'Watching a competitor with a worse product rank above you is infuriating. Especially when you have no idea what they\'re doing differently.',
        },
        {
          icon: <MapPinX className="size-6" />,
          title: '"I don\'t know if anything I\'m doing is actually working."',
          body: 'Is the blog helping? Did that change matter? Without real ranking data tied to your actions, you\'re flying blind.',
        },
      ].map((card, i) => (
        <div class="pain-card reveal" style={`transition-delay:${i*60}ms`}>
          <p class="text-2xl mb-3">{card.icon}</p>
          <p class="text-[0.9375rem] font-bold text-neutral-900 dark:text-stone-100 leading-snug mb-2">{card.title}</p>
          <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed">{card.body}</p>
        </div>
      ))}
    </div>

  </div>
</section>

<section class="bg-neutral-900 dark:bg-stone-100 border-t border-white/10 dark:border-black/10 py-24 px-6">
  <div class="max-w-[1200px] mx-auto">

    <div class="max-w-[700px] mx-auto text-center mb-16 reveal">
      <p class="text-xs font-bold uppercase tracking-widest text-white/40 dark:text-neutral-500 mb-4">The fix</p>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-white dark:text-neutral-900 tracking-tight leading-tight mb-6">
        What if SEO just… happened?
      </h2>
      <p class="text-lg text-white/70 dark:text-neutral-600 leading-relaxed">
        Sharkly is the AI SEO strategist that does the work for you. You plug in your website. It builds your strategy, writes your content, and tells you exactly what to do — in plain English, no jargon, no learning curve.
      </p>
    </div>

    <!-- Before / After -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-[900px] mx-auto">
      <div class="reveal rounded-2xl p-8 bg-white/5 dark:bg-black/5 border border-white/10 dark:border-black/10">
        <p class="text-xs font-bold uppercase tracking-widest text-white/30 dark:text-neutral-400 mb-5">Before Sharkly</p>
        {[
          'Hours of keyword research going nowhere',
          'Expensive agencies or confusing tools',
          'Blog posts that never rank',
          'No idea what your competitors are doing',
          'Guessing whether your SEO is working',
        ].map(item => (
          <div class="flex items-start gap-3 mb-3.5 last:mb-0">
            <span class="text-red-400 text-base mt-0.5 shrink-0">✕</span>
            <p class="text-sm text-white/60 dark:text-neutral-600 leading-snug">{item}</p>
          </div>
        ))}
      </div>
      <div class="reveal [transition-delay:100ms] rounded-2xl p-8 bg-emerald-500/10 dark:bg-emerald-500/5 border border-emerald-500/20 dark:border-emerald-500/10">
        <p class="text-xs font-bold uppercase tracking-widest text-emerald-400 dark:text-emerald-600 mb-5">After Sharkly</p>
        {[
          'Full strategy built automatically in 10 minutes',
          'Expert-level SEO from $39/month',
        //   'AI-written, Google-optimized content that ranks',
        'AI-written, graded, and optimized content backed by proprietary scoring algorithms',
          'Know exactly what\'s working — and what\'s not',
          'Rankings tracked, reported, explained in plain English',
        ].map(item => (
          <div class="flex items-start gap-3 mb-3.5 last:mb-0">
            <span class="text-emerald-400 text-base mt-0.5 shrink-0">✓</span>
            <p class="text-sm text-white/80 dark:text-neutral-700 leading-snug font-medium">{item}</p>
          </div>
        ))}
      </div>
    </div>

    <div class="text-center mt-12 reveal">
      <a href={`${appUrl}/signup`} class="inline-flex md:text-base text-sm items-center gap-2.5 bg-white dark:bg-neutral-900 text-neutral-900 dark:text-white px-7 py-3.5 rounded-full font-bold no-underline transition-opacity hover:opacity-85">
        Start free — see your strategy in 10 minutes →
      </a>
    </div>

  </div>
</section>

<!-- How it works — 3 steps -->
<section id="features" class="bg-stone-100 dark:bg-neutral-900 border-t border-black/10 dark:border-white/10 py-24 px-6">
  <div class="max-w-[1200px] mx-auto">

    <div class="text-center max-w-[560px] mx-auto mb-16 reveal">
      <p class="text-xs font-bold uppercase tracking-widest text-gray-400 mb-4">How it works</p>
      <h2 class="text-3xl sm:text-4xl font-extrabold text-neutral-900 dark:text-stone-100 tracking-tight leading-tight">
        Three steps to ranking on Google. None of them require SEO knowledge.
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-20">
      {[
        {
          step: '01',
          title: 'Plug in your website',
          body: 'Enter your URL and what you sell. Sharkly audits your site, analyses your competitors, and figures out exactly where your opportunities are.',
          time: 'Takes 2 minutes',
        },
        {
          step: '02',
          title: 'Get your strategy',
          body: 'Sharkly builds your complete SEO plan — ranked keywords, content clusters, topic priorities. All in plain English. No jargon, no spreadsheets.',
          time: 'Ready in ~10 minutes',
        },
        {
          step: '03',
          title: 'Publish and rank',
          body: 'Use Sharkly\'s AI to write fully optimized articles, then watch your rankings climb. Track everything from one simple dashboard.',
          time: 'Results in weeks, not months',
        },
      ].map((s, i) => (
        <div class="reveal" style={`transition-delay:${i*80}ms`}>
          <p class="text-4xl font-extrabold text-black/30 dark:text-white/30 tracking-tight mb-4">{s.step}</p>
          <h3 class="text-lg font-extrabold text-neutral-900 dark:text-stone-100 mb-2 leading-snug">{s.title}</h3>
          <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed mb-3">{s.body}</p>
          <p class="text-xs font-bold text-emerald-600 dark:text-emerald-400">{s.time}</p>
        </div>
      ))}
    </div>

  </div>
</section>

<!-- Feature 1: Site Audit + Strategy -->
<section id="strategy" class="bg-stone-100 dark:bg-neutral-900 border-t border-black/10 dark:border-white/10 py-24 px-6">
  <div class="max-w-[1200px] mx-auto">
    <div class="flex flex-col md:flex-row gap-12 lg:gap-20 items-center">

      <div class="flex-1 min-w-0 reveal">
        <p class="text-[0.6875rem] font-bold uppercase tracking-widest text-gray-400 dark:text-gray-500 mb-3">Strategy</p>
        <h2 class="text-2xl sm:text-3xl lg:text-[2rem] font-extrabold text-neutral-900 dark:text-stone-100 tracking-tight leading-tight mb-5 max-w-[380px]">
          Your complete SEO game plan. Built automatically.
        </h2>
        <p class="text-base text-gray-600 dark:text-gray-400 leading-relaxed mb-4 max-w-[400px]">
          Drop in your URL and niche. Sharkly reads your site, checks your competition, and builds a full ranked list of keyword opportunities sized exactly to your site's authority — so you only go after keywords you can actually win.
        </p>
        <p class="text-base text-gray-600 dark:text-gray-400 leading-relaxed mb-8 max-w-[400px]">
          No guesswork. No spreadsheets. A complete, prioritised strategy — in under 10 minutes.
        </p>
        <a href={`${appUrl}/strategy`} class="inline-flex items-center gap-2 text-[0.875rem] font-semibold text-neutral-900 dark:text-stone-100 no-underline hover:opacity-70">
          Learn about Strategy →
        </a>
      </div>

      <div class="flex-[1.1] min-w-0 reveal [transition-delay:150ms]">
        <div class="scenic-card">
          <div class="scenic-bg" style="background: linear-gradient(160deg, #7eb8e8 0%, #b0d0ee 40%, #90ba7a 70%, #c8c870 100%);"></div>
          <div class="scenic-panel">
            <div class="scenic-topbar">
              <div class="mac-dot" style="background:#ff5f57;"></div>
              <div class="mac-dot" style="background:#ffbd2e;"></div>
              <div class="mac-dot" style="background:#28c840;"></div>
              <div class="scenic-titlebar"></div>
            </div>
            <div class="p-3.5">
              <p class="text-[0.625rem] font-bold text-gray-400 uppercase tracking-widest mb-2.5">Your Keyword Opportunities</p>
              {[
                { kw: 'best running shoes for flat feet',  vol: '18K',  diff: 'Winnable', green: true  },
                { kw: 'minimalist running shoes women',    vol: '9.2K', diff: 'Winnable', green: true  },
                { kw: 'how to choose running shoes',      vol: '14K',  diff: 'Medium',   green: false },
                { kw: 'trail running shoes beginners',    vol: '7.8K', diff: 'Medium',   green: false },
                { kw: 'running shoes vs training shoes',  vol: '22K',  diff: 'Hard',     green: false },
              ].map(row => (
                <div class="flex items-center gap-2.5 py-2 px-1 border-b border-black/8 dark:border-white/8 last:border-0">
                  <span class="flex-[3] text-[0.6875rem] font-semibold text-neutral-900 dark:text-stone-100 truncate">{row.kw}</span>
                  <span class="text-[0.625rem] text-gray-400 whitespace-nowrap">{row.vol}/mo</span>
                  <span class={`text-[0.625rem] font-semibold px-1.5 py-0.5 rounded-full whitespace-nowrap ${row.green ? 'bg-emerald-100 text-emerald-800 dark:bg-emerald-950 dark:text-emerald-400' : 'bg-stone-200 text-gray-600 dark:bg-neutral-700 dark:text-gray-400'}`}>{row.diff}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- Feature 2: Content Generation -->
<section id="clusters" class="bg-stone-100 dark:bg-neutral-900 border-t border-black/10 dark:border-white/10 py-24 px-6">
  <div class="max-w-[1200px] mx-auto">
    <div class="flex flex-col md:flex-row-reverse gap-12 lg:gap-20 items-center">

      <div class="flex-1 min-w-0 reveal">
        <p class="text-[0.6875rem] font-bold uppercase tracking-widest text-gray-400 dark:text-gray-500 mb-3">Content</p>
        <h2 class="text-2xl sm:text-3xl lg:text-[2rem] font-extrabold text-neutral-900 dark:text-stone-100 tracking-tight leading-tight mb-5 max-w-[380px]">
          AI-written articles that are actually built to rank.
        </h2>
        <p class="text-base text-gray-600 dark:text-gray-400 leading-relaxed mb-4 max-w-[400px]">
          Sharkly doesn't just generate text — it builds every article around what Google actually wants to see. The right structure, the right headings, NLP-optimized language, competitor gaps filled. Edit anything, then publish.
        </p>
        <p class="text-base text-gray-600 dark:text-gray-400 leading-relaxed mb-8 max-w-[400px]">
          Topics are grouped into clusters — a money page plus supporting articles — so Google sees you as an authority, not a one-hit blog.
        </p>
        <a href={`${appUrl}/clusters`} class="inline-flex items-center gap-2 text-[0.875rem] font-semibold text-neutral-900 dark:text-stone-100 no-underline hover:opacity-70">
          Learn about Content Clusters →
        </a>
      </div>

      <div class="flex-1 min-w-0 reveal [transition-delay:100ms]">
        <div class="scenic-card">
          <div class="scenic-bg" style="background: linear-gradient(160deg, #d4956a 0%, #e8c87a 45%, #78b0d8 100%);"></div>
          <div class="scenic-panel">
            <div class="scenic-topbar">
              <div class="mac-dot" style="background:#ff5f57;"></div>
              <div class="mac-dot" style="background:#ffbd2e;"></div>
              <div class="mac-dot" style="background:#28c840;"></div>
              <div class="scenic-titlebar"></div>
            </div>
            <div class="p-3.5">
              <div class="bg-stone-100 dark:bg-neutral-800 rounded-lg p-3 mb-2.5">
                <div class="flex items-center gap-2 mb-2">
                  <div class="w-7 h-7 rounded-full bg-emerald-100 dark:bg-emerald-900 flex items-center justify-center shrink-0 text-xs">🤖</div>
                  <div>
                    <p class="text-[0.6875rem] font-bold text-neutral-900 dark:text-stone-100">Sharkly AI</p>
                    <p class="text-[0.625rem] text-gray-400">Content Brief Ready</p>
                  </div>
