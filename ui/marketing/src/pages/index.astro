          <h2 class="text-2xl font-extrabold text-neutral-900 dark:text-stone-100 tracking-tight">SEO explained in plain English — no jargon.</h2>
        </div>
        <a href="/blog" class="text-sm font-semibold text-gray-600 dark:text-gray-400 no-underline whitespace-nowrap hover:text-neutral-900 dark:hover:text-stone-100">View all articles →</a>
      </div>
      <div class="grid gap-5 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
        {featuredPosts.map(post => {
          const href = `/blog/${post.blog_categories?.slug ?? 'uncategorized'}/${post.slug}`;
          const date = post.published_at
            ? new Date(post.published_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })
            : '';
          return (
            <a href={href} class="flex flex-col rounded-xl border border-black/10 dark:border-white/10 overflow-hidden bg-white dark:bg-neutral-900 no-underline transition-shadow hover:shadow-lg">
              {post.og_image_url && (
                <div class="aspect-video overflow-hidden">
                  <img src={post.og_image_url} alt={post.title} loading="lazy" class="w-full h-full object-cover transition-transform duration-300 hover:scale-105" />
                </div>
              )}
              <div class="p-5 flex-1 flex flex-col gap-2">
                {post.blog_categories && (
                  <span class="text-[0.6875rem] font-bold text-gray-400 uppercase tracking-widest">{post.blog_categories.name}</span>
                )}
                <h3 class="text-[0.9375rem] font-bold text-neutral-900 dark:text-stone-100 leading-snug">{post.title}</h3>
                {post.excerpt && <p class="text-[0.8125rem] text-gray-600 dark:text-gray-400 flex-1 leading-snug">{post.excerpt}</p>}
                <p class="text-xs text-gray-400">{date}{post.reading_time_minutes ? ` · ${post.reading_time_minutes} min read` : ''}</p>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>
)}

<section class="bg-neutral-800 py-28 px-6 text-center">
  <div class="max-w-5xl mx-auto">
    <p class="text-3xl sm:text-4xl lg:text-[3.5rem] font-extrabold text-white dark:text-stone-100 tracking-tight leading-[1.05] mb-5">
      Your competitors are<br/>already ranking.<br/>
      <span class="text-white/50">Will you?</span>
    </p>
    <p class="text-white/65 text-[1.0625rem] mb-4 leading-relaxed max-w-[480px] mx-auto">
      Join 1,200+ small business owners who stopped guessing about SEO — and started ranking.
    </p>
    <p class="text-white/45 text-sm mb-10">
      Start your 7-day trial today.
    </p>
    <a href={`${appUrl}/signup`} class="inline-flex items-center gap-2.5 bg-white text-neutral-900 px-9 py-4 rounded-full font-bold text-base no-underline transition-opacity hover:opacity-85 shadow-xl">
      Start your trial — takes 2 minutes →
    </a>
    <div class="flex items-center justify-center gap-6 mt-6 flex-wrap">
      {['7-day trial', '10 mins to your first strategy', 'From $39/mo'].map(item => (
        <p class="text-xs text-white/80 flex items-center gap-1.5">
          <span class="text-emerald-500">✓</span> {item}
        </p>
      ))}
    </div>
  </div>
</section>

<script>
  const observer = new IntersectionObserver(
    entries => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); }),
    { threshold: 0.1 }
  );
  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
</script>

</BaseLayout>