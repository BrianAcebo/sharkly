---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { Search } from '@lucide/astro';
import { getPosts, getCategories, getFeaturedPosts } from '../../lib/supabase';
import { buildStaticMarketingPageJsonLd } from '../../lib/sitePageJsonLd';

const [categories, featured, recent] = await Promise.all([
  getCategories(),
  getFeaturedPosts(3),
  getPosts(),
]);

const recentNonFeatured = recent.filter(p => !p.featured).slice(0, 9);

const postsPayload = JSON.stringify(recent).replace(/</g, '\\u003c');

const siteUrl = (import.meta.env.MARKETING_URL as string | undefined) ?? 'https://sharkly.co';
const appUrl = import.meta.env.FRONTEND_URL ?? 'https://app.sharkly.co';
const blogCanonical = `${siteUrl}/blog`;
const blogDescription = 'SEO insights, glossary, and guides for small business owners.';
const blogEntityId = `${blogCanonical}#blog`;

const schema = buildStaticMarketingPageJsonLd({
  siteUrl,
  appUrl,
  canonicalUrl: blogCanonical,
  pageName: 'Sharkly Blog — SEO for Small Businesses',
  description:
    'Plain-English SEO guides, glossary definitions backed by Google patents, and real strategies for small business owners.',
  breadcrumbItems: [
    { name: 'Home', path: '/' },
    { name: 'Blog', path: '/blog' },
  ],
  mainEntity: { '@id': blogEntityId },
  extraGraph: [
    {
      '@type': 'Blog',
      '@id': blogEntityId,
      name: 'Sharkly Blog',
      description: blogDescription,
      url: blogCanonical,
      publisher: { '@id': `${siteUrl}#organization` },
    },
  ],
});
---

<BaseLayout
  title="Sharkly Blog — SEO for Small Businesses"
  description="Plain-English SEO guides, glossary definitions backed by Google patents, and real strategies for small business owners."
  canonical={blogCanonical}
  schema={schema}
>
  <div class="max-w-[1100px] mx-auto py-12 px-6">

    <div class="text-center mb-12">
      <h1 class="text-4xl font-bold text-neutral-900 mb-3 dark:text-stone-100">
        SEO Knowledge, Plain and Simple
      </h1>
      <p class="text-lg text-gray-500 max-w-[560px] mx-auto dark:text-gray-400">
        No jargon. No fluff. Just the stuff that actually moves the needle — backed by real data and Google patents.
      </p>

      <form action="/blog/search" method="get" class="mt-8 max-w-xl mx-auto" role="search">
        <label for="blog-index-search" class="sr-only">Search articles</label>
        <div class="flex flex-col gap-2 sm:flex-row sm:items-stretch rounded-full border border-gray-200 bg-white pl-4 pr-1 py-1 shadow-sm dark:border-neutral-700 dark:bg-neutral-900">
          <div class="relative flex-1 flex items-center min-w-0">
            <Search className="size-4 text-gray-400 shrink-0 mr-2 dark:text-gray-500" aria-hidden="true" />
            <input
              id="blog-index-search"
              type="search"
              name="q"
              placeholder="Search articles…"
              autocomplete="off"
              class="w-full min-w-0 border-0 bg-transparent py-2 text-sm text-neutral-900 placeholder:text-gray-400 focus:outline-none dark:text-stone-100 dark:placeholder:text-gray-500"
            />
          </div>
          <button
            type="submit"
            class="shrink-0 rounded-full bg-indigo-600 px-5 py-2 text-sm font-semibold text-white hover:bg-indigo-700 dark:bg-indigo-500 dark:hover:bg-indigo-400"
          >
            Search
          </button>
        </div>
      </form>

      <div id="blog-index-live-wrap" class="mt-10 hidden max-w-[1100px] mx-auto text-left">
        <h2 class="text-lg font-semibold text-neutral-900 mb-3 dark:text-stone-100">Matching articles</h2>
        <p
          id="blog-index-search-status"
          class="text-sm text-gray-500 mb-5 dark:text-gray-400 hidden"
          aria-live="polite"
        ></p>
        <div id="blog-index-live-results" class="hidden"></div>
      </div>
    </div>

    {categories.length > 0 && (
      <div class="flex gap-2 flex-wrap mb-10 justify-center">
        {categories.map(cat => (
          <a
            href={`/blog/${cat.slug}`}
            class="px-4 py-1.5 rounded-full border border-gray-200 text-sm text-gray-700 transition-colors duration-150 hover:bg-gray-50 hover:border-gray-300 dark:border-neutral-700 dark:text-gray-300 dark:hover:bg-neutral-800 dark:hover:border-neutral-600"
          >
            {cat.name}
          </a>
        ))}
      </div>
    )}

    {featured.length > 0 && (
      <section class="mb-12">
        <h2 class="text-lg font-semibold text-neutral-900 mb-5 dark:text-stone-100">Featured</h2>
        <div class="grid gap-6 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
          {featured.map(post => <PostCard post={post} featured={true} />)}
        </div>
      </section>
    )}

    {recentNonFeatured.length > 0 && (
      <section>
        <h2 class="text-lg font-semibold text-neutral-900 mb-5 dark:text-stone-100">Latest</h2>
        <div class="grid gap-6 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
          {recentNonFeatured.map(post => <PostCard post={post} />)}
        </div>
      </section>
    )}

    {recent.length === 0 && (
      <div class="text-center py-16 text-gray-400 dark:text-gray-500">
        <p>Coming soon. Check back shortly.</p>
      </div>
    )}

    <script type="application/json" id="blog-index-posts-payload" set:html={postsPayload} />
    <script>
      import { mountBlogLiveSearch } from '../../lib/blogLiveSearch';

      const raw = document.getElementById('blog-index-posts-payload')?.textContent ?? '[]';
      const posts = JSON.parse(raw);
      mountBlogLiveSearch({
        posts,
        input: '#blog-index-search',
        resultsContainer: '#blog-index-live-results',
        statusEl: '#blog-index-search-status',
        showHideWrap: '#blog-index-live-wrap',
        debounceMs: 280,
      });
    </script>
  </div>
</BaseLayout>
