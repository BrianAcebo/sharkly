---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { Search } from '@lucide/astro';
import { getPosts } from '../../lib/supabase';
import { filterPostsBySearchQuery } from '../../lib/blogSearch';
import { buildStaticMarketingPageJsonLd } from '../../lib/sitePageJsonLd';

const siteUrl = (import.meta.env.MARKETING_URL as string | undefined) ?? 'https://sharkly.co';
const appUrl = import.meta.env.FRONTEND_URL ?? 'https://app.sharkly.co';
const searchCanonical = `${siteUrl}/blog/search`;

const rawQ = Astro.url.searchParams.get('q') ?? '';
const q = rawQ.trim();

const allPosts = await getPosts();
const hasQuery = q.length > 0;
const results = hasQuery ? filterPostsBySearchQuery(allPosts, q) : [];

const title = hasQuery
  ? `Search: “${q}” | Sharkly Blog`
  : 'Search the blog | Sharkly Blog';

const description = hasQuery
  ? `${results.length} result${results.length !== 1 ? 's' : ''} for “${q}” on the Sharkly blog.`
  : 'Search SEO guides and articles on the Sharkly blog.';

const schema = buildStaticMarketingPageJsonLd({
  siteUrl,
  appUrl,
  canonicalUrl: searchCanonical,
  pageName: title,
  description,
  breadcrumbItems: [
    { name: 'Home', path: '/' },
    { name: 'Blog', path: '/blog' },
    { name: 'Search', path: '/blog/search' },
  ],
});

const postsPayload = JSON.stringify(allPosts).replace(/</g, '\\u003c');
---

<BaseLayout title={title} description={description} canonical={searchCanonical} schema={schema}>
  <div class="max-w-[1100px] mx-auto py-12 px-6">
    <nav class="text-sm text-gray-400 mb-6 dark:text-gray-500">
      <a href="/blog" class="hover:text-gray-600 dark:hover:text-gray-400">Blog</a>
      <span class="mx-2">›</span>
      <span class="text-gray-700 font-medium dark:text-gray-300">Search</span>
    </nav>

    <h1 class="text-3xl font-bold text-neutral-900 mb-2 dark:text-stone-100">Search articles</h1>
    <p class="text-base text-gray-500 max-w-[640px] mb-8 dark:text-gray-400">
      Find guides and glossary posts by title, topic, or keywords in the excerpt. Results update as you type.
    </p>

    <form action="/blog/search" method="get" class="mb-10" role="search">
      <label for="blog-search-q" class="sr-only">Search blog posts</label>
      <div
        class="flex flex-col gap-3 sm:flex-row sm:items-stretch max-w-2xl rounded-xl border border-gray-200 bg-white p-2 shadow-sm dark:border-neutral-700 dark:bg-neutral-900"
      >
        <div class="relative flex-1 flex items-center min-w-0">
          <Search
            className="absolute left-3 size-5 text-gray-400 pointer-events-none dark:text-gray-500 shrink-0"
            aria-hidden="true"
          />
          <input
            id="blog-search-q"
            type="search"
            name="q"
            value={q}
            placeholder="e.g. canonical, internal links, schema…"
            autocomplete="off"
            class="w-full rounded-lg border-0 bg-transparent py-2.5 pl-11 pr-3 text-neutral-900 placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-indigo-500/40 dark:text-stone-100 dark:placeholder:text-gray-500"
          />
        </div>
        <button
          type="submit"
          class="shrink-0 rounded-lg bg-indigo-600 px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-indigo-700 dark:bg-indigo-500 dark:hover:bg-indigo-400"
        >
          Search
        </button>
      </div>
    </form>

    <p
      id="blog-search-status"
      class="text-sm text-gray-500 mb-6 dark:text-gray-400 hidden"
      aria-live="polite"
    >
    </p>

    <div id="blog-live-results" class="hidden"></div>

    <div
      id="blog-search-hint"
      class="rounded-xl border border-dashed border-gray-200 bg-gray-50/80 px-6 py-10 text-center text-gray-500 dark:border-neutral-700 dark:bg-neutral-900/50 dark:text-gray-400"
    >
      <p class="mb-1 font-medium text-neutral-800 dark:text-stone-200">Looking for something specific?</p>
      <p class="text-sm">Start typing — we’ll match titles, excerpts, and categories.</p>
    </div>

    <noscript>
      {
        hasQuery ? (
          <>
            <p class="text-sm text-gray-500 mb-6 dark:text-gray-400">
              {results.length === 0 ? (
                <>
                  No articles match <span class="font-medium text-neutral-700 dark:text-gray-300">“{q}”</span>.
                </>
              ) : (
                <>
                  {results.length} article{results.length !== 1 ? 's' : ''} matching{' '}
                  <span class="font-medium text-neutral-700 dark:text-gray-300">“{q}”</span>
                </>
              )}
            </p>
            {results.length > 0 && (
              <div class="grid gap-6 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
                {results.map((post) => (
                  <PostCard post={post} />
                ))}
              </div>
            )}
          </>
        ) : (
          <p class="text-sm text-gray-500 dark:text-gray-400">Turn on JavaScript for live search, or use the Search button.</p>
        )
      }
    </noscript>

    <script type="application/json" id="blog-posts-payload" set:html={postsPayload} />
    <script>
      import { mountBlogLiveSearch } from '../../lib/blogLiveSearch';

      const raw = document.getElementById('blog-posts-payload')?.textContent ?? '[]';
      const posts = JSON.parse(raw);
      mountBlogLiveSearch({
        posts,
        input: '#blog-search-q',
        resultsContainer: '#blog-live-results',
        statusEl: '#blog-search-status',
        emptyHintEl: '#blog-search-hint',
        syncUrl: '/blog/search',
        debounceMs: 280,
      });
    </script>
  </div>
</BaseLayout>
