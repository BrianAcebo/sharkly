---
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  ShoppingBag,
  Zap,
  CheckCircle,
  Upload,
  Search,
  FileText,
  BarChart2,
  Target,
  Package,
  AlertCircle,
  ArrowRight,
} from '@lucide/astro';

const shopifyAppUrl = import.meta.env.PUBLIC_SHOPIFY_APP_URL ?? import.meta.env.VITE_SHOPIFY_APP_URL ?? 'https://app.sharkly.co/signup?source=shopify';
const appUrl       = import.meta.env.FRONTEND_URL ?? 'https://app.sharkly.co';
const siteUrl      = import.meta.env.MARKETING_URL ?? 'https://sharkly.co';
const canonicalUrl = `${siteUrl}/shopify`;

const pageTitle       = 'Easy SEO for Shopify Stores';
const metaDescription = 'Connect your Shopify store to Sharkly. Get a full SEO strategy, AI-written product descriptions, 6 on-page checks, and one-click publish back — without learning SEO.';

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebPage',
      '@id': `${canonicalUrl}#webpage`,
      url: canonicalUrl,
      name: pageTitle,
      description: metaDescription,
      isPartOf: { '@id': `${siteUrl}#website` },
    },
    {
      '@type': 'SoftwareApplication',
      name: 'Sharkly for Shopify',
      applicationCategory: 'BusinessApplication',
      operatingSystem: 'Web',
      offers: { '@type': 'Offer', price: '39', priceCurrency: 'USD', priceValidUntil: '2027-01-01' },
      description: metaDescription,
    },
    { '@type': 'WebSite', '@id': `${siteUrl}#website`, url: siteUrl, name: 'Sharkly' },
  ],
};
---

<BaseLayout
  title={pageTitle}
  description={metaDescription}
  canonical={canonicalUrl}
  schema={schema}
>

<style is:global>
  /* ── Tokens ── */
  :root {
    --g-green: #96bf48;
    --g-green-dark: #5a8f00;
    --g-green-pale: #f2f7eb;
    --border: rgba(0,0,0,.08);
    --border-d: rgba(255,255,255,.08);
  }
  .dark { --g-green-pale: rgba(150,191,72,.07); }

  /* ── Reveal ── */
  .reveal { opacity:0; transform:translateY(22px); transition:opacity .5s ease,transform .5s ease; }
  .reveal.visible { opacity:1; transform:none; }

  /* ── Scenic card (same system as homepage) ── */
  .scenic-card { border-radius:16px; overflow:hidden; box-shadow:0 24px 64px rgba(0,0,0,.15); }
  .scenic-bg   { height:72px; }
  .scenic-panel {
    background:#fff; border-radius:10px 10px 0 0;
    margin:0 14px; transform:translateY(-26px);
    box-shadow:0 4px 20px rgba(0,0,0,.10); overflow:hidden;
  }
  .dark .scenic-panel { background:#171717; }
  .scenic-topbar {
    display:flex; align-items:center; gap:5px;
    padding:8px 12px; border-bottom:1px solid rgba(0,0,0,.07); background:#f5f5f4;
  }
  .dark .scenic-topbar { background:#222; border-color:rgba(255,255,255,.07); }
  .mac-dot { width:8px; height:8px; border-radius:50%; }
  .scenic-titlebar { flex:1; height:11px; background:#e7e5e4; border-radius:3px; margin:0 8px; }
  .dark .scenic-titlebar { background:#333; }

  /* ── Shopify badge ── */
  .shopify-badge {
    display:inline-flex; align-items:center; gap:8px;
    background:var(--g-green-pale); border:1px solid rgba(150,191,72,.4);
    border-radius:999px; padding:7px 16px;
    font-size:0.9375rem; font-weight:700; color:#3d6b00; letter-spacing:.01em;
  }
  .dark .shopify-badge { background:rgba(150,191,72,.1); color:#96bf48; border-color:rgba(150,191,72,.3); }

  /* ── Check row ── */
  .check-row {
    display:flex; align-items:center; gap:14px;
    padding:13px 0; border-bottom:1px solid var(--border);
    font-size:1.0625rem; font-weight:600; color:#171717;
  }
  .dark .check-row { border-color:var(--border-d); color:#f5f5f0; }
  .check-row:last-child { border:none; }

  /* ── Cards ── */
  .pain-card {
    background:#fff; border:1px solid rgba(0,0,0,.08);
    border-radius:16px; padding:28px; box-shadow:0 2px 12px rgba(0,0,0,.05);
  }
  .dark .pain-card { background:#1a1a1a; border-color:rgba(255,255,255,.08); }

  .testimonial-card {
    background:#fff; border:1px solid rgba(0,0,0,.08);
    border-radius:18px; padding:32px; box-shadow:0 4px 20px rgba(0,0,0,.05);
  }
  .dark .testimonial-card { background:#1a1a1a; border-color:rgba(255,255,255,.08); }
</style>

<!-- ══════════════════════════════════════════
     HERO
     ══════════════════════════════════════════ -->
<section class="bg-stone-100 dark:bg-neutral-900 pt-20 sm:pt-24 pb-0 px-4 sm:px-6 overflow-hidden">
  <div class="max-w-[1100px] mx-auto">

    <div class="text-center max-w-[740px] mx-auto mb-12 space-y-6">

      <div class="inline-flex justify-center">
        <span class="shopify-badge">
          <ShoppingBag className="size-5 shrink-0" />
          Built for Shopify stores
        </span>
      </div>

      <h1 class="text-4xl sm:text-5xl lg:text-[3.5rem] font-extrabold text-neutral-900 dark:text-stone-100 leading-[1.07] tracking-tight">
        Your products deserve<br class="hidden sm:block" />
        to show up on Google.
      </h1>

      <p class="text-xl sm:text-2xl text-gray-500 dark:text-gray-400 leading-relaxed mx-auto">
        Connect your Shopify store to Sharkly. Full SEO strategy, AI-written product copy, and one-click publish — no SEO knowledge needed.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 pt-2">
        <a href={shopifyAppUrl} class="w-full sm:w-auto inline-flex items-center justify-center gap-2.5 bg-neutral-900 dark:bg-stone-100 text-white dark:text-neutral-900 px-8 py-4 rounded-full text-base font-bold no-underline transition-opacity hover:opacity-85 shadow-lg">
          <ShoppingBag className="size-5 shrink-0" />
          Install on Shopify — 7-day trial
        </a>
        <a href={`${appUrl}/signup`} class="inline-flex items-center gap-2 text-base font-semibold text-gray-500 dark:text-gray-400 no-underline hover:text-neutral-900 dark:hover:text-stone-100">
          Sign up without Shopify <ArrowRight className="size-4" />
        </a>
      </div>

      <p class="text-sm text-gray-400">7-day trial · Cancel anytime · From $39/mo</p>
    </div>

    <!-- Hero SVG — Shopify store before/after -->
    <div class="max-w-[860px] mx-auto reveal overflow-x-auto">
      <svg width="100%" viewBox="0 0 860 280" xmlns="http://www.w3.org/2000/svg" font-family="system-ui,-apple-system,sans-serif">

        <rect width="860" height="280" rx="18" fill="#f4f2ec"/>
      
        <!-- LEFT CARD -->
        <rect x="24" y="24" width="340" height="232" rx="12" fill="#fff" stroke="rgba(0,0,0,.08)" stroke-width="1"/>
        <text x="40" y="52" font-size="10" font-weight="700" fill="#9ca3af" letter-spacing="1">RIGHT NOW</text>
      
        <!-- Pain 1 -->
        <circle cx="52" cy="80" r="10" fill="#fee2e2"/>
        <line x1="47" y1="75" x2="57" y2="85" stroke="#dc2626" stroke-width="1.5" stroke-linecap="round"/>
        <line x1="57" y1="75" x2="47" y2="85" stroke="#dc2626" stroke-width="1.5" stroke-linecap="round"/>
        <text x="70" y="77" font-size="12.5" font-weight="600" fill="#374151">Paying for every single visitor</text>
        <text x="70" y="92" font-size="11" fill="#9ca3af">Stop ads, sales dry up instantly</text>
        <line x1="40" y1="108" x2="348" y2="108" stroke="rgba(0,0,0,.05)" stroke-width="1"/>
      
        <!-- Pain 2 -->
        <circle cx="52" cy="130" r="10" fill="#fee2e2"/>
        <line x1="47" y1="125" x2="57" y2="135" stroke="#dc2626" stroke-width="1.5" stroke-linecap="round"/>
        <line x1="57" y1="125" x2="47" y2="135" stroke="#dc2626" stroke-width="1.5" stroke-linecap="round"/>
        <text x="70" y="127" font-size="12.5" font-weight="600" fill="#374151">Google can't find your products</text>
        <text x="70" y="142" font-size="11" fill="#9ca3af">No keyword, no meta, no schema</text>
        <line x1="40" y1="158" x2="348" y2="158" stroke="rgba(0,0,0,.05)" stroke-width="1"/>
      
        <!-- Pain 3 -->
        <circle cx="52" cy="180" r="10" fill="#fee2e2"/>
        <line x1="47" y1="175" x2="57" y2="185" stroke="#dc2626" stroke-width="1.5" stroke-linecap="round"/>
        <line x1="57" y1="175" x2="47" y2="185" stroke="#dc2626" stroke-width="1.5" stroke-linecap="round"/>
        <text x="70" y="177" font-size="12.5" font-weight="600" fill="#374151">Competitors rank above you</text>
        <text x="70" y="192" font-size="11" fill="#9ca3af">On keywords your products should own</text>
      
        <!-- CENTRE -->
        <line x1="430" y1="32" x2="430" y2="118" stroke="#96bf48" stroke-width="2" stroke-dasharray="5 4"/>
        <rect x="390" y="118" width="80" height="34" rx="17" fill="#96bf48"/>
        <text x="430" y="140" text-anchor="middle" font-size="11" font-weight="800" fill="#fff" letter-spacing="1">SHARKLY</text>
        <line x1="430" y1="152" x2="430" y2="238" stroke="#96bf48" stroke-width="2" stroke-dasharray="5 4"/>
        <polygon points="422,238 430,252 438,238" fill="#96bf48"/>
      
        <!-- RIGHT CARD -->
        <rect x="496" y="24" width="340" height="232" rx="12" fill="#fff" stroke="rgba(150,191,72,.4)" stroke-width="1.5"/>
        <text x="512" y="52" font-size="10" font-weight="700" fill="#9ca3af" letter-spacing="1">WITH SHARKLY</text>
      
        <!-- Fix 1 -->
        <circle cx="528" cy="80" r="10" fill="#dcfce7"/>
        <polyline points="523,80 527,84.5 534,75.5" fill="none" stroke="#16a34a" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        <text x="546" y="77" font-size="12.5" font-weight="600" fill="#374151">Customers find you for free</text>
        <text x="546" y="92" font-size="11" fill="#9ca3af">Google sends traffic while you sleep</text>
        <line x1="512" y1="108" x2="824" y2="108" stroke="rgba(0,0,0,.05)" stroke-width="1"/>
      
        <!-- Fix 2 -->
        <circle cx="528" cy="130" r="10" fill="#dcfce7"/>
        <polyline points="523,130 527,134.5 534,125.5" fill="none" stroke="#16a34a" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        <text x="546" y="127" font-size="12.5" font-weight="600" fill="#374151">Every product page optimised</text>
        <text x="546" y="142" font-size="11" fill="#9ca3af">AI copy, schema, meta — one click</text>
        <line x1="512" y1="158" x2="824" y2="158" stroke="rgba(0,0,0,.05)" stroke-width="1"/>
      
        <!-- Fix 3 -->
        <circle cx="528" cy="180" r="10" fill="#dcfce7"/>
        <polyline points="523,180 527,184.5 534,175.5" fill="none" stroke="#16a34a" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        <text x="546" y="177" font-size="12.5" font-weight="600" fill="#374151">Stop depending on paid ads</text>
        <text x="546" y="192" font-size="11" fill="#9ca3af">Traffic that compounds every month</text>
      
      </svg>
    </div>

  </div>
</section>

<!-- ══════════════════════════════════════════
     WHAT YOU GET — 3 icon cards
     ══════════════════════════════════════════ -->
<section class="bg-stone-100 dark:bg-neutral-900 px-4 sm:px-6 py-16">
  <div class="max-w-[1100px] mx-auto">
    <hr class="border-0 border-t border-black/10 dark:border-white/10 mb-12"/>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 sm:gap-10">
      {[
        { Icon: Zap,          title: 'Import in one click',       body: 'Connect Shopify. Sharkly pulls your products and collections automatically — no CSV, no manual entry.' },
        { Icon: CheckCircle,  title: '6 SEO checks per page',     body: 'Keyword in title, H1, URL, meta, originality, and Product schema. Pass or fail — with a plain-English fix for each.' },
        { Icon: Upload,       title: 'Publish back to Shopify',   body: 'One click writes your optimised description, meta title, meta description, and JSON-LD schema straight to your store.' },
      ].map(({ Icon, title, body }, i) => (
        <div class="reveal" style={`transition-delay:${i*80}ms`}>
          <div class="w-14 h-14 rounded-2xl bg-emerald-50 dark:bg-emerald-950/40 flex items-center justify-center mb-5">
            <Icon className="size-7 text-emerald-600 dark:text-emerald-400" />
          </div>
          <p class="text-xl font-bold text-neutral-900 dark:text-stone-100 mb-2.5">{title}</p>
          <p class="text-base text-gray-500 dark:text-gray-400 leading-relaxed">{body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════════
     THE PROBLEM
     ══════════════════════════════════════════ -->
<section class="bg-stone-200 dark:bg-neutral-800 border-t border-black/10 dark:border-white/10 py-20 px-4 sm:px-6">
  <div class="max-w-[1100px] mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 lg:gap-20 items-center">

      <div class="reveal">
        <p class="text-sm font-bold uppercase tracking-widest text-gray-400 mb-5">The problem</p>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-neutral-900 dark:text-stone-100 tracking-tight leading-tight mb-8">
          Your product pages are invisible.<br/>And you probably don't know why.
        </h2>
        <div class="space-y-5">
          {[
            'Shopify gives you a store. It doesn\'t do SEO.',
            'Most product descriptions are manufacturer copy — duplicate content Google ignores.',
            'No keyword, no meta description, no schema. Google can\'t rank what it can\'t understand.',
            'Apps that promise "SEO" add a star rating or a redirect. That\'s not real SEO.',
          ].map(item => (
            <div class="flex items-start gap-4">
              <AlertCircle className="size-6 text-red-400 shrink-0 mt-0.5" />
              <p class="text-base sm:text-lg text-gray-600 dark:text-gray-400 leading-relaxed">{item}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- SERP illustration -->
      <div class="reveal [transition-delay:100ms] flex justify-center">
        <svg viewBox="0 0 340 296" xmlns="http://www.w3.org/2000/svg" class="w-full max-w-sm" aria-hidden="true">
          <rect width="340" height="296" rx="16" fill="white" stroke="rgba(0,0,0,.07)" stroke-width="1"/>
          <rect x="14" y="14" width="312" height="32" rx="16" fill="#f3f4f6"/>
          <text x="30" y="35" fill="#9ca3af" font-size="11.5" font-family="system-ui">best running shoes for flat feet</text>
          <g transform="translate(14,62)">
            <text x="0" y="14" fill="#1a73e8" font-size="10.5" font-weight="600" font-family="system-ui">bigbrand.com</text>
            <text x="0" y="30" fill="#111" font-size="12.5" font-weight="700" font-family="system-ui">Best Running Shoes — Free Shipping</text>
            <rect x="292" y="0" width="28" height="28" rx="5" fill="rgba(150,191,72,.15)" stroke="rgba(150,191,72,.3)" stroke-width="1"/>
            <text x="306" y="18" text-anchor="middle" fill="#5a8f00" font-size="9.5" font-weight="800" font-family="system-ui">#1</text>
          </g>
          <g transform="translate(14,110)">
            <text x="0" y="14" fill="#1a73e8" font-size="10.5" font-weight="600" font-family="system-ui">competitor.co</text>
            <text x="0" y="30" fill="#111" font-size="12.5" font-weight="700" font-family="system-ui">Flat Feet Running Shoes — Shop Now</text>
            <rect x="292" y="0" width="28" height="28" rx="5" fill="rgba(150,191,72,.15)" stroke="rgba(150,191,72,.3)" stroke-width="1"/>
            <text x="306" y="18" text-anchor="middle" fill="#5a8f00" font-size="9.5" font-weight="800" font-family="system-ui">#2</text>
          </g>
          <g transform="translate(14,158)">
            <text x="0" y="14" fill="#1a73e8" font-size="10.5" font-weight="600" font-family="system-ui">anotherbrand.com</text>
            <text x="0" y="30" fill="#111" font-size="12.5" font-weight="700" font-family="system-ui">Running Shoes for Flat Feet</text>
            <rect x="292" y="0" width="28" height="28" rx="5" fill="rgba(150,191,72,.15)" stroke="rgba(150,191,72,.3)" stroke-width="1"/>
            <text x="306" y="18" text-anchor="middle" fill="#5a8f00" font-size="9.5" font-weight="800" font-family="system-ui">#3</text>
          </g>
          <g transform="translate(14,214)">
            <rect width="312" height="66" rx="10" fill="#fef2f2" stroke="#fca5a5" stroke-width="1"/>
