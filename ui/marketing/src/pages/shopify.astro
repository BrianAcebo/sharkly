            <rect x="280" y="8" width="24" height="24" rx="5" fill="#fee2e2" stroke="#fca5a5" stroke-width="1"/>
            <text x="292" y="24" text-anchor="middle" fill="#ef4444" font-size="12" font-weight="800" font-family="system-ui">?</text>
          </g>
        </svg>
      </div>

    </div>
  </div>
</section>

<!-- ══════════════════════════════════════════
     HOW IT WORKS — 4 steps
     ══════════════════════════════════════════ -->
<section class="bg-stone-100 dark:bg-neutral-900 border-t border-black/10 dark:border-white/10 py-20 px-4 sm:px-6">
  <div class="max-w-[1100px] mx-auto">

    <div class="text-center max-w-[520px] mx-auto mb-14 reveal">
      <p class="text-sm font-bold uppercase tracking-widest text-gray-400 mb-3">How it works</p>
      <h2 class="text-3xl sm:text-4xl font-extrabold text-neutral-900 dark:text-stone-100 tracking-tight leading-tight">
        Four steps from invisible to ranking.
      </h2>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-6">
      {[
        { Icon: ShoppingBag, n: '01', title: 'Connect your store',      body: 'Install the Shopify app. Sharkly pulls your products and collections — 250 products in seconds.' },
        { Icon: Search,      n: '02', title: 'Assign keywords',          body: 'Pick a target keyword per product or collection. Sharkly shows you the best opportunities your store can actually win.' },
        { Icon: FileText,    n: '03', title: 'Run checks & generate',    body: '6 on-page SEO checks. Generate an original, keyword-optimised description in one click — with Product schema included.' },
        { Icon: Upload,      n: '04', title: 'Publish back to Shopify',  body: 'One click writes optimised copy, meta title, meta description, and JSON-LD schema directly to your Shopify storefront.' },
      ].map(({ Icon, n, title, body }, i) => (
        <div class="reveal" style={`transition-delay:${i*80}ms`}>
          <div class="w-14 h-14 rounded-2xl bg-emerald-50 dark:bg-emerald-950/40 flex items-center justify-center mb-5">
            <Icon className="size-7 text-emerald-600 dark:text-emerald-400" />
          </div>
          <p class="text-xs font-bold text-gray-300 dark:text-neutral-600 tracking-widest mb-2">{n}</p>
          <h3 class="text-xl font-extrabold text-neutral-900 dark:text-stone-100 mb-2 leading-snug">{title}</h3>
          <p class="text-base text-gray-500 dark:text-gray-400 leading-relaxed">{body}</p>
        </div>
      ))}
    </div>

  </div>
</section>

<!-- ══════════════════════════════════════════
     FEATURE: 6 SEO Checks + scenic card
     ══════════════════════════════════════════ -->
<section class="bg-stone-100 dark:bg-neutral-900 border-t border-black/10 dark:border-white/10 py-20 px-4 sm:px-6">
  <div class="max-w-[1100px] mx-auto">
    <div class="flex flex-col md:flex-row gap-12 lg:gap-20 items-center">

      <div class="flex-1 min-w-0 reveal">
        <span class="shopify-badge mb-6 inline-flex">
          <ShoppingBag className="size-5" />
          Shopify feature
        </span>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-neutral-900 dark:text-stone-100 tracking-tight leading-tight mb-5 max-w-[420px]">
          Every product page gets its own SEO report.
        </h2>
        <p class="text-lg text-gray-500 dark:text-gray-400 leading-relaxed mb-8 max-w-[420px]">
          6 checks. Pass or fail. Fix instructions in plain English — no jargon, no guessing what to change.
        </p>
        <div class="max-w-[420px]">
          {[
            'Keyword in title tag',
            'Keyword in H1 heading',
            'Keyword in URL slug',
            'Meta description 150–160 characters',
            'Original description (no duplicate content)',
            'Product schema (JSON-LD)',
          ].map(item => (
            <div class="check-row">
              <span class="w-7 h-7 rounded-full bg-emerald-100 dark:bg-emerald-950 flex items-center justify-center shrink-0">
                <CheckCircle className="size-4 text-emerald-600 dark:text-emerald-400" />
              </span>
              {item}
            </div>
          ))}
        </div>
      </div>

      <!-- Scenic card -->
      <div class="flex-[1.1] min-w-0 w-full reveal [transition-delay:120ms]">
        <div class="scenic-card">
          <div class="scenic-bg" style="background: linear-gradient(150deg, #78b878 0%, #96bf48 50%, #c8e870 100%);"></div>
          <div class="scenic-panel">
            <div class="scenic-topbar">
              <div class="mac-dot" style="background:#ff5f57;"></div>
              <div class="mac-dot" style="background:#ffbd2e;"></div>
              <div class="mac-dot" style="background:#28c840;"></div>
              <div class="scenic-titlebar"></div>
            </div>
            <div class="p-5">
              <div class="flex items-center gap-3 mb-4 pb-4 border-b border-black/8 dark:border-white/8">
                <div class="w-10 h-10 rounded-xl bg-emerald-100 dark:bg-emerald-900 flex items-center justify-center shrink-0">
                  <Package className="size-5 text-emerald-600 dark:text-emerald-400" />
                </div>
                <div class="flex-1 min-w-0">
                  <p class="text-sm font-bold text-neutral-900 dark:text-stone-100 truncate">Minimalist Running Shoe — Women</p>
                  <p class="text-xs text-gray-400 truncate">yourstore.myshopify.com/products/...</p>
                </div>
                <span class="text-xs font-bold px-2.5 py-1 rounded-full bg-emerald-100 text-emerald-800 dark:bg-emerald-950 dark:text-emerald-400 shrink-0">6/6 ✓</span>
              </div>
              {[
                'Keyword in title tag',
                'Keyword in H1',
                'Keyword in URL slug',
                'Meta description (154 chars)',
                'Original description',
