---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Zap, Check, Sparkles, ArrowRight } from '@lucide/astro';

const appUrl = import.meta.env.FRONTEND_URL ?? 'https://app.sharkly.co';
const siteUrl = import.meta.env.MARKETING_URL ?? 'https://sharkly.co';
const canonicalUrl = `${siteUrl}/pricing`;

const pageTitle = 'Pricing';
const metaDescription = 'Simple, honest pricing. AI-powered SEO strategy, content generation, and rankings — from $39/month. 7-day trial. No contracts.';

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebPage',
      '@id': `${canonicalUrl}#webpage`,
      url: canonicalUrl,
      name: pageTitle,
      description: metaDescription,
      isPartOf: { '@id': `${siteUrl}#website` },
    },
    {
      '@type': 'Product',
      name: 'Sharkly SEO',
      description: metaDescription,
      brand: { '@type': 'Brand', name: 'Sharkly' },
      offers: [
        { '@type': 'Offer', name: 'Builder', price: '39', priceCurrency: 'USD', priceValidUntil: '2027-12-31' },
        { '@type': 'Offer', name: 'Growth', price: '79', priceCurrency: 'USD', priceValidUntil: '2027-12-31' },
        { '@type': 'Offer', name: 'Scale', price: '119', priceCurrency: 'USD', priceValidUntil: '2027-12-31' },
        // { '@type': 'Offer', name: 'Pro', price: '169', priceCurrency: 'USD', priceValidUntil: '2027-12-31' },
      ],
    },
    { '@type': 'WebSite', '@id': `${siteUrl}#website`, url: siteUrl, name: 'Sharkly' },
  ],
};

const tiers = [
  {
    name: 'Builder',
    tagline: 'For business owners ready to start getting found on Google.',
    price: 39,
    credits: 250,
    sites: '1 site',
    output: '~1 cluster/mo',
    cta: 'Start trial',
    featured: false,
    categories: [
      { label: 'SEO Strategy', items: ['AI topic discovery', 'Competitor analysis', 'Topic cluster planning', 'Customer journey map'] },
      { label: 'Content Creation', items: ['AI article & focus page writer', 'SEO briefs', 'Built-in editor', 'Real-time SEO score'] },
      { label: 'Ecommerce SEO', items: ['Product & collection optimizer', 'Shopify publishing'] },
      { label: 'Content Intelligence', items: ['Cluster architecture warnings', 'Keyword cannibalization detection'] },
    ],
  },
  {
    name: 'Growth',
    tagline: 'For growing businesses that want to see what\'s actually working.',
    price: 79,
    credits: 600,
    sites: 'Unlimited sites',
    output: '~2–3 clusters/mo',
    cta: 'Start trial',
    featured: true,
    badge: 'Most Popular',
    categories: [
      { label: 'Everything in Builder', items: [] },
      { label: 'Rankings & Performance', items: ['Performance dashboard', 'Live traffic per page', 'Keyword rankings', 'Navboost momentum', 'CTR optimization'] },
      { label: 'Internal Linking', items: ['Link suggestions with placement', 'Link status tracking'] },
      { label: 'Advanced Intelligence', items: ['Fin AI Assistant (200 messages/mo)', '"Diagnose This Page" tool', 'Re-optimization queue (coming soon)'] },
    ],
  },
  {
    name: 'Scale',
    tagline: 'For serious operators who want every SEO advantage working for them.',
    price: 119,
    credits: 1100,
    sites: 'Unlimited sites',
    output: '~4–5 clusters/mo',
    cta: 'Start trial',
    featured: false,
    categories: [
      { label: 'Everything in Growth', items: [] },
      { label: 'Technical SEO Health', items: ['Full site audit', 'Broken links, redirects', 'Duplicate content finder', 'Core Web Vitals'] },
      { label: 'Trust & Authority', items: ['EEAT checklist', 'Author & schema markup', 'Brand search tracker'] },
      { label: 'Image & Speed', items: ['Image SEO scanner', 'Weekly health monitoring'] },
      { label: 'AI Assistant', items: ['Fin AI Assistant (500 messages/mo)'] },
    ],
  },
  // Pro — commented out for now, come back later
  // {
  //   name: 'Pro',
  //   tagline: 'For power users who run SEO like a business.',
  //   price: 169,
  //   credits: 2500,
  //   sites: 'Unlimited sites',
  //   output: '10+ clusters/mo',
  //   cta: 'Join waitlist',
  //   featured: false,
  //   badge: 'Coming Soon',
  //   waitlist: true,
  //   categories: [
  //     { label: 'Everything in Scale', items: [] },
  //     { label: 'Agency & Professional', items: ['White-label reports', 'Client-ready exports', 'Multi-site dashboard'] },
  //     { label: 'Advanced Intelligence', items: ['Competitor monitoring', 'Content gap reports', 'Revenue attribution'] },
  //   ],
  // },
];

const allPlansInclude = [
  'Google Search Console integration',
  'AI-powered content strategy',
  'Conversion checklist on every page',
  'Cluster architecture warnings',
  'Schema markup generator',
  'Shopify publishing',
  '7-day trial',
  'Fin AI Assistant — Growth+ plans (200–500 messages/mo)',
];
---

<BaseLayout
  title={pageTitle}
  description={metaDescription}
  canonical={canonicalUrl}
  schema={schema}
>

<style is:global>
  .pricing-page .tier-card {
    border-radius: 1rem;
    border: 1px solid rgba(0,0,0,.1);
    overflow: hidden;
    background: #fff;
    transition: all 0.2s ease;
  }
  .dark .pricing-page .tier-card {
    border-color: rgba(255,255,255,.1);
    background: #171717;
  }
  .pricing-page .tier-card:hover {
    box-shadow: 0 20px 25px -5px rgba(0,0,0,.1), 0 8px 10px -6px rgba(0,0,0,.1);
  }
  .pricing-page .tier-card.featured {
    border-width: 2px;
    border-color: #171717;
    box-shadow: 0 25px 50px -12px rgba(0,0,0,.25);
  }
  .dark .pricing-page .tier-card.featured {
    border-color: #f5f5f0;
    box-shadow: 0 25px 50px -12px rgba(0,0,0,.5);
  }
  .pricing-page .category-block {
    border-bottom: 1px solid rgba(0,0,0,.08);
  }
  .pricing-page .category-block:last-child {
    border-bottom: none;
  }
  .dark .pricing-page .category-block {
    border-color: rgba(255,255,255,.08);
  }
</style>

<!-- Hero -->
<section class="pricing-page bg-stone-100 dark:bg-neutral-900 pt-16 sm:pt-24 pb-12 px-4 sm:px-6">
  <div class="max-w-[1100px] mx-auto text-center">
    <p class="text-xs font-bold uppercase tracking-widest text-gray-400 dark:text-gray-500 mb-4">Simple, honest pricing</p>
    <h1 class="text-4xl sm:text-5xl lg:text-[3.25rem] font-extrabold text-neutral-900 dark:text-stone-100 tracking-tight leading-[1.1] mb-6">
      SEO that actually works —<br class="hidden sm:block" />
      <span class="text-neutral-500 dark:text-neutral-400">without the agency price tag.</span>
    </h1>
    <p class="text-lg sm:text-xl text-gray-600 dark:text-gray-400 max-w-[560px] mx-auto leading-relaxed mb-8">
      Every plan includes AI strategy, content generation, and plain-English guidance. Upgrade as you grow — downgrade anytime.
    </p>
    <a href={`${appUrl}/signup`} class="inline-flex items-center gap-2 bg-neutral-900 dark:bg-stone-100 text-white dark:text-neutral-900 px-7 py-3.5 rounded-full text-base font-bold no-underline transition-opacity hover:opacity-85 shadow-lg">
      Start your 7-day trial
      <ArrowRight className="size-4" />
    </a>
  </div>
</section>

<!-- Tier cards -->
<section class="pricing-page bg-stone-100 dark:bg-neutral-900 pb-20 px-4 sm:px-6">
  <div class="max-w-[1200px] mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 lg:gap-6">
      {tiers.map((tier, i) => (
        <div class={`tier-card ${tier.featured ? 'featured' : ''} relative`}>
          {tier.badge && (
            <div class={`absolute top-0 left-0 right-0 text-center py-2 text-[0.6875rem] font-bold uppercase tracking-widest ${tier.featured ? 'bg-neutral-900 dark:bg-stone-100 text-white dark:text-neutral-900' : 'bg-stone-200 dark:bg-neutral-700 text-gray-600 dark:text-gray-300'}`}>
              {tier.badge}
            </div>
          )}
          <div class={`p-6 ${tier.badge ? 'pt-14' : ''}`}>
            <div class="flex items-center gap-2 mb-2">
              <h2 class="text-xl font-extrabold text-neutral-900 dark:text-stone-100">{tier.name}</h2>
              {tier.featured && <Sparkles className="size-4 text-amber-500" />}
            </div>
            <p class="text-sm text-gray-600 dark:text-gray-400 mb-4 min-h-[40px]">{tier.tagline}</p>
            <div class="flex items-baseline gap-1 mb-1">
              <span class="text-3xl font-extrabold text-neutral-900 dark:text-stone-100">${tier.price}</span>
              <span class="text-sm text-gray-400">/mo</span>
            </div>
            <p class="text-xs font-semibold text-emerald-600 dark:text-emerald-400 mb-0.5">{tier.credits} credits/mo</p>
            <p class="text-xs text-gray-500 dark:text-gray-500 mb-5">{tier.sites} · {tier.output}</p>
            <a
              href={tier.waitlist ? `${appUrl}/signup?plan=pro` : `${appUrl}/signup`}
              class={`block text-center py-3 rounded-xl text-sm font-bold no-underline transition-opacity hover:opacity-85 mb-6 ${tier.featured ? 'bg-neutral-900 dark:bg-stone-100 text-white dark:text-neutral-900' : 'bg-stone-100 dark:bg-neutral-800 text-neutral-900 dark:text-stone-100 border border-black/10 dark:border-white/10'}`}
            >
              {tier.cta}
            </a>
            <div class="space-y-4">
              {tier.categories.map((cat) => (
                <div class="category-block pb-4 last:pb-0">
                  <p class="text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400 mb-2">{cat.label}</p>
                  {cat.items.length > 0 ? (
                    <ul class="space-y-1.5">
                      {cat.items.map((item) => (
                        <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
                          <Check className="size-4 text-emerald-500 shrink-0 mt-0.5" />
                          {item}
                        </li>
                      ))}
                    </ul>
                  ) : (
                    <p class="text-xs text-gray-500 italic">Included</p>
                  )}
                </div>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- CRO Add-on banner -->
<section class="pricing-page bg-stone-200 dark:bg-neutral-800 border-y border-black/10 dark:border-white/10 py-12 px-4 sm:px-6">
  <div class="max-w-[900px] mx-auto">
    <div class="p-6 sm:p-8 rounded-2xl bg-white dark:bg-neutral-900 border border-black/10 dark:border-white/10">
      <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-6 mb-6">
        <div class="flex items-center gap-3 shrink-0">
          <div class="w-12 h-12 rounded-xl bg-amber-100 dark:bg-amber-900/40 flex items-center justify-center">
            <Zap className="size-6 text-amber-600 dark:text-amber-400" />
          </div>
          <div>
            <h3 class="font-bold text-lg text-neutral-900 dark:text-stone-100">CRO Add-on</h3>
            <p class="text-sm text-gray-500">+$29/mo · Available on any plan · New feature</p>
          </div>
        </div>
        <span class="shrink-0 px-5 py-2.5 rounded-xl text-sm font-semibold bg-amber-100 dark:bg-amber-900/40 text-amber-800 dark:text-amber-200 no-underline hover:opacity-85 transition-opacity">
          New Feature
        </span>
      </div>
      <p class="text-sm text-gray-600 dark:text-gray-400 flex-1 max-w-2xl">
        Turn SEO traffic into paying customers. A separate workspace for your destination pages — product pages, service pages, signup flows — with conversion-focused audits and exact copy fixes.
      </p>
      <div class="mt-6 pt-6 border-t border-black/10 dark:border-white/10">
        <p class="text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400 mb-3">Includes</p>
        <ul class="grid grid-cols-1 sm:grid-cols-2 gap-2">
          {['CRO Studio — dedicated workspace for conversion pages', 'Full conversion audit — 5 dimensions', 'Exact copy fixes with placement instructions', 'Psychological triggers audit', 'Objection removal audit', 'Funnel visualizer — destination card unlocked'].map((item) => (
            <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
              <Check className="size-4 text-amber-500 shrink-0 mt-0.5" />
              {item}
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>

<!-- All plans include -->
<section class="pricing-page bg-stone-100 dark:bg-neutral-900 py-16 px-4 sm:px-6">
  <div class="max-w-[900px] mx-auto">
    <h2 class="text-xl font-extrabold text-neutral-900 dark:text-stone-100 text-center mb-8">
      Every plan includes
    </h2>
    <div class="flex flex-wrap justify-center gap-x-8 gap-y-3">
      {allPlansInclude.map((item) => (
        <div class="flex items-center gap-2 text-sm text-gray-700 dark:text-gray-300">
          <Check className="size-4 text-emerald-500 shrink-0" />
          {item}
        </div>
      ))}
    </div>
    <p class="text-center text-sm text-gray-500 dark:text-gray-400 mt-6">
      Overage credits: $0.05/credit · Never expire
    </p>
  </div>
</section>

<!-- Social proof + final CTA -->
<section class="pricing-page bg-stone-200 dark:bg-neutral-800 border-t border-black/10 dark:border-white/10 py-20 px-4 sm:px-6">
  <div class="max-w-[680px] mx-auto text-center">
    <p class="text-sm font-semibold text-emerald-600 dark:text-emerald-400 mb-4">
      Trusted by 1,200+ small business owners
    </p>
    <h2 class="text-2xl sm:text-3xl font-extrabold text-neutral-900 dark:text-stone-100 tracking-tight mb-4">
      Less than your monthly coffee budget.<br />Way more than an agency.
    </h2>
    <p class="text-base text-gray-600 dark:text-gray-400 mb-8">
      No contracts. No surprise fees. Cancel anytime. Start with a 7-day trial.
    </p>
    <a href={`${appUrl}/signup`} class="inline-flex items-center gap-2.5 bg-neutral-900 dark:bg-stone-100 text-white dark:text-neutral-900 px-8 py-4 rounded-full text-base font-bold no-underline transition-opacity hover:opacity-85 shadow-lg">
      Start your 7-day trial
      <ArrowRight className="size-4" />
    </a>
  </div>
</section>

</BaseLayout>
