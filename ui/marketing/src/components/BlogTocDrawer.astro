---
import type { BlogTocItem } from '../lib/blogToc';

interface Props {
	toc: BlogTocItem[];
	/** Suffix for unique ids (e.g. desktop / mobile) */
	suffix: string;
	/** Extra classes on the outer wrapper */
	class?: string;
}

const { toc, suffix, class: className } = Astro.props;
const panelId = `blog-toc-panel-${suffix}`;
const navId = `blog-toc-links-${suffix}`;
---

<div
	class:list={[
		'blog-toc-drawer group/toc inline-flex max-w-full flex-row items-start overflow-hidden rounded-xl border border-emerald-200/80 bg-emerald-50/70 shadow-sm data-[toc-expanded=false]:h-11 data-[toc-expanded=true]:h-auto dark:border-emerald-800/50 dark:bg-neutral-900/50',
		className
	]}
	data-toc-expanded="false"
>
	<button
		type="button"
		class="blog-toc-toggle flex h-11 w-11 shrink-0 items-center justify-center text-emerald-800 transition-colors hover:bg-emerald-100/80 dark:text-emerald-300 dark:hover:bg-neutral-800/80"
		aria-expanded="false"
		aria-controls={navId}
		aria-label="Open table of contents"
		title="Table of contents"
	>
		<svg
			class="toc-icon-hamburger size-5"
			viewBox="0 0 24 24"
			fill="none"
			stroke="currentColor"
			stroke-width="2"
			stroke-linecap="round"
			aria-hidden="true"
		>
			<path d="M4 6h16M4 12h16M4 18h16"></path>
		</svg>
		<svg
			class="toc-icon-close hidden size-5"
			viewBox="0 0 24 24"
			fill="none"
			stroke="currentColor"
			stroke-width="2"
			stroke-linecap="round"
			stroke-linejoin="round"
			aria-hidden="true"
		>
			<path d="m15 18-6-6 6-6"></path>
		</svg>
	</button>
	<div
		class="blog-toc-panel max-h-[min(70vh,calc(100vh-20rem))] toc-motion-panel h-0 w-0 min-h-0 min-w-0 overflow-hidden border-transparent transition-[width,height] duration-300 ease-out data-[expanded=true]:h-[min(70vh,calc(100vh-8rem))] data-[expanded=true]:w-[min(260px,calc(100vw-3.5rem))] data-[expanded=true]:border-emerald-200/40 dark:data-[expanded=true]:border-emerald-800/40"
		data-expanded="false"
		id={panelId}
	>
		<nav
			id={navId}
			class="h-full min-h-0 w-[min(260px,calc(100vw-3.5rem))] overflow-y-auto scrollbar-branded py-3.5 pr-3 pl-2"
			aria-label="Table of contents"
		>
			<p class="mb-2 px-1 text-[10px] sm:text-xs font-bold uppercase tracking-wider text-neutral-600 dark:text-stone-400">
				Table of contents
			</p>
			<ul class="space-y-2 list-disc border-emerald-300/60 p-2 text-sm leading-snug dark:border-neutral-600">
				{toc.map((item) => (
					<li>
						<a
							href={`#${item.id}`}
							class="block text-gray-500 transition-colors hover:text-gray-600 dark:text-gray-400 dark:hover:text-gray-300"
						>
							{item.label}
						</a>
					</li>
				))}
			</ul>
		</nav>
	</div>
</div>

<style is:global>
	@media (prefers-reduced-motion: reduce) {
		.blog-toc-drawer,
		.blog-toc-drawer .toc-motion-panel {
			transition: none !important;
		}
	}
</style>
