---
import { cn } from '../lib/utils'; 

interface Props {
  width?: number | 'auto';
  height?: number | 'auto';
  isIcon?: boolean;
  className?: string;
  alt?: string;
  fetchPriority?: 'high' | 'low' | 'auto';
}

const appUrl = import.meta.env.PUBLIC_APP_URL ?? 'https://app.sharkly.co';

const { width = 200, height = 65, isIcon = false, className, alt = 'Sharkly logo', fetchPriority = 'high' } = Astro.props;
const iconWidth = Number(width) / 4 || 'auto';
const iconHeight = Number(height) / 4 || 'auto';
---

<img src={`${appUrl}/images/logos/logo.svg`} alt={alt} class={cn('dark:hidden block', className)} width={width} height={height} fetchpriority={fetchPriority} title={alt} />
<img src={`${appUrl}/images/logos/logo-dark.svg`} alt={alt} class={cn('hidden dark:block', className)} width={width} height={height} fetchpriority={fetchPriority} title={alt} />
<!-- <img src={`${appUrl}/images/logos/logo-icon.svg`} alt={alt} class={className} width={iconWidth} height={iconHeight} fetchpriority={fetchPriority} title={alt} />
<img src={`${appUrl}/images/logos/logo-icon-dark.svg`} alt={alt} class={className} width={iconWidth} height={iconHeight} fetchpriority={fetchPriority} title={alt} /> -->