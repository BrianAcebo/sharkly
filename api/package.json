{
	"name": "sharkly-api",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "tsx watch src/index.ts",
		"build": "tsc -p tsconfig.json",
		"start": "node dist/index.js",
		"ngrok": "node scripts/ngrok-serve.mjs",
		"stop": "tsx ../scripts/stop-dev.ts 3000",
		"fly": "cd ../.. && fly deploy --config api/fly.toml -a sharkly-api"
	},
	"dependencies": {
		"@anthropic-ai/sdk": "^0.78.0",
		"@supabase/supabase-js": "^2.50.0",
		"axios": "^1.13.6",
		"cheerio": "^1.2.0",
		"cors": "^2.8.5",
		"date-fns": "^4.1.0",
		"date-fns-tz": "^3.2.0",
		"dotenv": "^17.2.1",
		"exifr": "^7.1.3",
		"express": "^5.1.0",
		"multer": "^2.1.1",
		"ngrok": "^5.0.0-beta.2",
		"node-fetch": "^3.3.2",
		"openai": "^6.25.0",
		"pdf-parse": "^1.1.1",
		"playwright": "^1.58.2",
		"resend": "^4.0.0",
		"robots-parser": "^3.0.1",
		"serverless-http": "^4.0.0",
		"stripe": "^18.3.0",
		"tcp-port-used": "^1.0.2",
		"uuid": "^13.0.0",
		"zod": "^4.1.12"
	},
	"devDependencies": {
		"@types/cors": "^2.8.17",
		"@types/express": "^4.17.21",
		"@types/multer": "^2.1.0",
		"@types/node": "^20.11.24",
		"tsx": "^4.20.6",
		"typescript": "~5.7.2"
	}
}
